# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth2 (create credentials at console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Google Drive folder ID (from the URL of your shared folder)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# SQLite database path (only used when Postgres is not configured)
# Default: ~/.ocr-mcp/books.db
DATABASE_PATH=./data/books.db

# Credentials directory for storing OAuth tokens
CREDENTIALS_PATH=./credentials

# External PostgreSQL (optional — leave unset to use local SQLite)
# Primary: separate vars (recommended for enterprise/secrets managers)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false
# Alternative: single connection string (overrides separate vars if set)
DATABASE_URL=

# Application user identity (optional — stamped on records for attribution)
APP_USER_ID=
